# Receives a timezone name (e.g. "America/New_York") on stdin,
# symlinks the corresponding zoneinfo file, and records it in /etc/timezone
tz=$(cat)
ln -sf /usr/share/zoneinfo/"$tz" /etc/localtime
echo "$tz" > /etc/timezone
