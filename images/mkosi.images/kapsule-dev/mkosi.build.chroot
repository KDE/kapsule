#!/bin/sh
# SPDX-FileCopyrightText: 2026 Lasath Fernando <devel@lasath.org>
#
# SPDX-License-Identifier: GPL-3.0-or-later

# Build script — runs inside the image chroot with the build overlay mounted.
# Source tree is bind-mounted at $SRCDIR/kapsule via BuildSources=.
# Install to $DESTDIR so mkosi copies only the build outputs into the image.
# The build overlay (including /tmp/kapsule-build) is discarded automatically.

set -eux

cmake -B /tmp/kapsule-build -S "$SRCDIR/kapsule" \
  -G Ninja \
  -DCMAKE_INSTALL_PREFIX=/usr \
  -DCMAKE_BUILD_TYPE=RelWithDebInfo \
  -DKDE_INSTALL_USE_QT_SYS_PATHS=ON \
  -DBUILD_TESTING=OFF \
  -DCMAKE_INSTALL_LIBEXECDIR=lib \
  -DVENDOR_PYTHON_DEPS=OFF

cmake --build /tmp/kapsule-build
DESTDIR="$DESTDIR" cmake --install /tmp/kapsule-build
